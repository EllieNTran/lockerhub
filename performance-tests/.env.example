# Performance Test Configuration
# Copy this file to .env and update with your actual values

# Service URLs
WEBAPP_BASE_URL=http://host.docker.internal:3001
API_BASE_URL=http://host.docker.internal:3002
AUTH_BASE_URL=http://host.docker.internal:3003
BOOKING_BASE_URL=http://host.docker.internal:3004
ADMIN_BASE_URL=http://host.docker.internal:3005
NOTIFICATIONS_BASE_URL=http://host.docker.internal:3006
ANALYTICS_BASE_URL=http://host.docker.internal:3007

# Test User Credentials
TEST_USER_EMAIL=test.user@example.com
TEST_USER_PASSWORD=testpassword123

# Test Admin Credentials
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=adminpassword123

# InfluxDB Configuration
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=lockerhub-perf-token
INFLUXDB_ORG=lockerhub
INFLUXDB_BUCKET=k6
