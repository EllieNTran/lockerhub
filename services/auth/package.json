{
  "name": "auth",
  "version": "1.0.0",
  "description": "Authentication service for LockerHub",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/app.ts --bundle --platform=node --packages=external --outdir=dist --format=esm",
    "start": "env-cmd -e perf -- node dist/app.js",
    "dev": "env-cmd -e debug -- tsx watch src/app.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "auth",
    "jwt",
    "authentication"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "env-cmd": "^11.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-jose": "^2.2.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/ui": "^2.1.8",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.1.9"
  }
}
