{
  "name": "notifications",
  "version": "1.0.0",
  "description": "Notifications service for LockerHub",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "env-cmd -e perf -- node dist/app.js",
    "dev": "env-cmd -e debug -- tsx watch src/app.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "env-cmd -e test -- node dist/app.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "notifications"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "compression": "^1.7.5",
    "env-cmd": "^11.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "node-jose": "^2.2.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/node-cache": "^4.1.3",
    "@types/pg": "^8.18.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  }
}
